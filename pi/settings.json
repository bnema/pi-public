{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "packages": [
    "npm:pi-mcp-adapter",
    "npm:pi-web-access",
    "npm:@howaboua/pi-auto-trees"
  ],
  "subagents": {
    "agentOverrides": {
      "backend-data": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "low"
      },
      "context-builder": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "medium"
      },
      "delegate": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "low"
      },
      "oracle": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "medium"
      },
      "planner": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "medium"
      },
      "researcher": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "medium"
      },
      "reviewer": {
        "model": "openai-codex/gpt-5.5",
        "thinking": "medium"
      },
      "scout": {
        "model": "opencode-go/deepseek-v4-flash",
        "thinking": "minimal"
      },
      "worker": {
        "model": "opencode-go/deepseek-v4-flash",
        "thinking": "medium"
      }
    }
  },
  "enabledModels": [
    "openai-codex/gpt-5.5",
    "openai-codex/gpt-5.4",
    "openai-codex/gpt-5.4-mini"
  ],
  "theme": "noctalia"
}
